#include<stdio.h>
void main(){
    int m,a;
    scanf("%d", &m);
    if(m<=12)
        a=1;
    else if(m<=19 && m>12)
        a=2;
    else if(m<=30 && m>19)
        a=3;
    else if(m<=60 && m>30)
        a=4;
    else if(m<=100 && m>60)
        a=5;
    switch(a) {
        case 1:
            printf("Child");
            break;
        case 2:
            printf("Teenage");
            break;
        case 3:
            printf("Adult");
            break;
        case 4:
            printf("Middle age");
            break;
        case 5:
            printf("Senior citizen");
            break;
        default:
            printf("Do not exist");
            break;
    }
}
