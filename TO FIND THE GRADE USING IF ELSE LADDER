#include <stdio.h>
int main() {
    int mark;
    scanf("%d", &mark);
    if(mark>90)
     printf("Grade:S");
    else if(mark>80 && mark<=90)
     printf("Grade:A");
    else if(mark>70 && mark<=80)
      printf("Grade:B");
    else if(mark>60 && mark<=70)
     printf("Grade:C");
    else if(mark>=55 && mark<=60)
     printf("Grade:D");
    else if(mark>=50 && mark<55)
     printf("Grade:E");
    else
     printf("Fail");
    return 0;
}
