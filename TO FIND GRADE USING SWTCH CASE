#include <stdio.h>
int main() {
    int mark;
    scanf("%d",&mark);
    switch (mark/10){
        case 10:
        case 9:
            printf("Grade:S");
            break;
        case 8:
            printf("Grade:A");
            break;
        case 7:
            printf("Grade:B");
            break;
        case 6:
            printf("Grade:C");
            break;
        case 5:
            if(mark>=55)
                printf("Grade:D");
            else
                printf("Grade:E");
                break;
        default:
            printf("Fail");
    }
    return 0;
}
